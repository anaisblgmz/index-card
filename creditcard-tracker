  const [loading, setLoading] = useState(true);
  const [expandedCards, setExpandedCards] = useState(() => new Set(CARDS.map(c => c.id)));

  useEffect(() => {
    (async () => {
      try {
        const result = await window.storage.get('benefit_usage');
        if (result && result.value) setUsage(JSON.parse(result.value));
      } catch (e) {}
      setLoading(false);
    })();
  }, []);

  useEffect(() => {
    if (loading) return;
    (async () => {
      try { await window.storage.set('benefit_usage', JSON.stringify(usage)); }
      catch (e) { console.error('save failed', e); }
    })();
  }, [usage, loading]);

  const toggleBenefit = (benefitId, cadence) => {
    const period = getCurrentPeriod(cadence);
    const key = `${benefitId}::${period}`;
    setUsage(prev => {
      const next = { ...prev };
      if (next[key]) delete next[key];
      else next[key] = { usedAt: new Date().toISOString() };
      return next;
    });
  };

  const resetAll = () => {
    if (confirm('Clear all tracked benefit usage? This cannot be undone.')) setUsage({});
  };

  const stats = useMemo(() => {
    let claimedValue = 0;
    let availableValue = 0;
    let totalBenefits = 0;
    let usedBenefits = 0;
    CARDS.forEach(card => {
      card.benefits.forEach(b => {
        if (b.passive) return;
        if (!isBenefitActiveNow(b.cadence)) return;
        totalBenefits++;
        const period = getCurrentPeriod(b.cadence);
        const used = !!usage[`${b.id}::${period}`];
        availableValue += b.value;
        if (used) { claimedValue += b.value; usedBenefits++; }
      });
    });
    return { claimedValue, availableValue, totalBenefits, usedBenefits };
  }, [usage]);

  const urgentBenefits = useMemo(() => {
    const list = [];
    CARDS.forEach(card => {
      card.benefits.forEach(b => {
        if (b.passive) return;
        if (!isBenefitActiveNow(b.cadence)) return;
        const period = getCurrentPeriod(b.cadence);
        if (usage[`${b.id}::${period}`]) return;
        list.push({ card, benefit: b, days: daysUntilExpiry(b.cadence) });
      });
    });
    return list.sort((a, b) => a.days - b.days);
