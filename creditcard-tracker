      <path d="M 41 56 Q 44 58 47 56" stroke="#3a3026" stroke-width="1.2" fill="none" stroke-linecap="round"/>
      <path d="M 37 61 L 40 61 L 38.5 63 Z" fill="#d4a5a5"/>
      <path d="M 40 50 Q 45 52 48 56 L 46 58 Q 42 54 39 53 Z" fill="#7a6d5e" opacity="0.7"/>
      <ellipse cx="55" cy="78" rx="8" ry="5" fill="#f5f1e8"/>
      <text x="20" y="42" font-family="serif" font-size="8" fill="#7ea16b" font-style="italic">z</text>
      <text x="14" y="34" font-family="serif" font-size="6" fill="#7ea16b" font-style="italic">z</text>
    </svg>`;
  }
  if (which === 'watcher') {
    return `<svg class="cat-svg" viewBox="0 0 100 100" width="${size}" height="${size}">
      <ellipse cx="50" cy="78" rx="20" ry="14" fill="#fafaf7"/>
      <ellipse cx="50" cy="62" rx="16" ry="20" fill="#fafaf7"/>
      <circle cx="50" cy="42" r="16" fill="#fafaf7"/>
      <path d="M 38 32 L 36 22 L 44 30 Z" fill="#fafaf7"/>
      <path d="M 62 32 L 64 22 L 56 30 Z" fill="#fafaf7"/>
      <path d="M 39 31 L 38 26 L 42 30 Z" fill="#e8b5b5"/>
      <path d="M 61 31 L 62 26 L 58 30 Z" fill="#e8b5b5"/>
      <ellipse cx="43" cy="42" rx="2.5" ry="3.5" fill="#7ea16b"/>
      <ellipse cx="57" cy="42" rx="2.5" ry="3.5" fill="#7ea16b"/>
      <ellipse cx="43" cy="42" rx="0.8" ry="2.5" fill="#1c3144"/>
      <ellipse cx="57" cy="42" rx="0.8" ry="2.5" fill="#1c3144"/>
      <ellipse cx="50" cy="52" rx="2" ry="1.5" fill="#1c3144"/>
      <path d="M 48 48 L 52 48 L 50 50 Z" fill="#d4a5a5"/>
      <path d="M 50 50 Q 47 52 45 51" stroke="#3a3026" stroke-width="0.8" fill="none"/>
      <path d="M 50 50 Q 53 52 55 51" stroke="#3a3026" stroke-width="0.8" fill="none"/>
      <line x1="35" y1="48" x2="42" y2="49" stroke="#3a3026" stroke-width="0.4"/>
      <line x1="35" y1="51" x2="42" y2="50" stroke="#3a3026" stroke-width="0.4"/>
      <line x1="65" y1="48" x2="58" y2="49" stroke="#3a3026" stroke-width="0.4"/>
      <line x1="65" y1="51" x2="58" y2="50" stroke="#3a3026" stroke-width="0.4"/>
      <ellipse cx="45" cy="80" rx="4" ry="3" fill="#fafaf7"/>
      <ellipse cx="55" cy="80" rx="4" ry="3" fill="#fafaf7"/>
    </svg>`;
  }
  // strategist
  return `<svg class="cat-svg" viewBox="0 0 100 100" width="${size}" height="${size}">
    <ellipse cx="50" cy="70" rx="34" ry="20" fill="#1c2530"/>
    <ellipse cx="48" cy="74" rx="14" ry="8" fill="#fafaf7"/>
    <circle cx="38" cy="56" r="15" fill="#1c2530"/>
    <path d="M 32 58 Q 35 64 38 65 Q 41 64 44 58 Q 42 55 38 55 Q 34 55 32 58 Z" fill="#fafaf7"/>
    <path d="M 28 48 L 26 38 L 34 46 Z" fill="#1c2530"/>
    <path d="M 48 48 L 50 38 L 42 46 Z" fill="#1c2530"/>
    <path d="M 33 54 Q 36 53 38 54" stroke="#7ea16b" stroke-width="1.5" fill="none" stroke-linecap="round"/>
    <path d="M 40 54 Q 43 53 45 54" stroke="#7ea16b" stroke-width="1.5" fill="none" stroke-linecap="round"/>
    <path d="M 37 60 L 40 60 L 38.5 62 Z" fill="#d4a5a5"/>
    <line x1="25" y1="60" x2="33" y2="61" stroke="#fafaf7" stroke-width="0.4"/>
    <line x1="44" y1="61" x2="52" y2="60" stroke="#fafaf7" stroke-width="0.4"/>
    <ellipse cx="60" cy="78" rx="6" ry="4" fill="#fafaf7"/>
    <ellipse cx="72" cy="76" rx="5" ry="3" fill="#fafaf7"/>
  </svg>`;
}

const CATS = {
  napper:     { name: 'Gatito', role: 'The Napper',     tagline: 'guards the easy wins' },
  watcher:    { name: 'Luci',   role: 'The Watcher',    tagline: 'never misses an expiration' },
  strategist: { name: 'Loki',   role: 'The Strategist', tagline: 'plays the long game' }
};

// ---------- ICONS (Lucide-style inline SVG) ----------
const ICONS = {
  check: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>',
  clock: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>',
  refresh: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"></polyline><polyline points="1 20 1 14 7 14"></polyline><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path></svg>',
