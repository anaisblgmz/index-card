/* ================================================================
   HELPERS
================================================================ */
function getCurrentPeriod(cadence, date) {
  date = date || new Date();
  const y = date.getFullYear();
  const m = date.getMonth();
  if (cadence === 'monthly') return y + '-' + String(m+1).padStart(2,'0');
  if (cadence === 'annual') return '' + y;
  if (cadence === 'semiannual_h1') return y + '-H1';
  if (cadence === 'semiannual_h2') return y + '-H2';
  if (['q1','q2','q3','q4'].includes(cadence)) return y + '-' + cadence.toUpperCase();
  return y + '-' + String(m+1).padStart(2,'0');
}

function isBenefitActiveNow(cadence, date) {
  date = date || new Date();
  const m = date.getMonth();
  if (cadence === 'monthly' || cadence === 'annual') return true;
  if (cadence === 'semiannual_h1') return m <= 5;
  if (cadence === 'semiannual_h2') return m >= 6;
  if (cadence === 'q1') return m <= 2;
  if (cadence === 'q2') return m >= 3 && m <= 5;
  if (cadence === 'q3') return m >= 6 && m <= 8;
  if (cadence === 'q4') return m >= 9;
  return true;
}

function daysUntilExpiry(cadence, date) {
  date = date || new Date();
  const y = date.getFullYear();
  const m = date.getMonth();
  let end;
  if (cadence === 'monthly') end = new Date(y, m + 1, 0);
  else if (cadence === 'annual') end = new Date(y, 11, 31);
  else if (cadence === 'semiannual_h1') end = new Date(y, 5, 30);
  else if (cadence === 'semiannual_h2') end = new Date(y, 11, 31);
  else if (cadence === 'q1') end = new Date(y, 2, 31);
  else if (cadence === 'q2') end = new Date(y, 5, 30);
  else if (cadence === 'q3') end = new Date(y, 8, 30);
  else if (cadence === 'q4') end = new Date(y, 11, 31);
  else return 999;
  const diff = Math.ceil((end - date) / (1000 * 60 * 60 * 24));
  return Math.max(0, diff);
}

function cadenceLabel(cadence) {
  if (cadence === 'monthly') return 'Monthly';
  if (cadence === 'annual') return 'Annual';
  if (cadence === 'semiannual_h1') return 'Jan–Jun';
  if (cadence === 'semiannual_h2') return 'Jul–Dec';
  if (cadence.startsWith('q')) return cadence.toUpperCase();
  return cadence;
}

function escapeHtml(s) {
  return String(s)
    .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;').replace(/'/g,'&#039;');
}

/* ================================================================
   STATE
================================================================ */
const STORAGE_KEY = 'card_perks_usage_v1';
const EXPANDED_KEY = 'card_perks_expanded_v1';

let usage = {};
let expandedCards = new Set(CARDS.map(c => c.id));

function loadState() {
  try {
    const u = localStorage.getItem(STORAGE_KEY);
    if (u) usage = JSON.parse(u);
  } catch(e) {}
  try {
    const e = localStorage.getItem(EXPANDED_KEY);
    if (e) {
      const arr = JSON.parse(e);
      if (Array.isArray(arr)) expandedCards = new Set(arr);
    }
  } catch(e) {}
}

function saveUsage() {
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(usage)); } catch(e) {}
}
function saveExpanded() {
  try { localStorage.setItem(EXPANDED_KEY, JSON.stringify(Array.from(expandedCards))); } catch(e) {}
}

function toggleBenefit(benefitId, cadence) {
  const period = getCurrentPeriod(cadence);
  const key = benefitId + '::' + period;
  if (usage[key]) delete usage[key];
  else usage[key] = { usedAt: new Date().toISOString() };
  saveUsage();
  render();
}

function toggleCardExpanded(id) {
  if (expandedCards.has(id)) expandedCards.delete(id);
  else expandedCards.add(id);
  saveExpanded();
  render();
}

function resetAll() {
  if (confirm('Clear all tracked benefit usage? This cannot be undone.')) {
    usage = {};
    saveUsage();
    render();
  }
}

/* ================================================================
   COMPUTED
================================================================ */
function computeStats() {
  let claimedValue = 0, availableValue = 0, totalBenefits = 0, usedBenefits = 0;
  CARDS.forEach(card => {
    card.benefits.forEach(b => {
      if (b.passive) return;
      if (!isBenefitActiveNow(b.cadence)) return;
      totalBenefits++;
      const used = !!usage[b.id + '::' + getCurrentPeriod(b.cadence)];
      availableValue += b.value;
      if (used) { claimedValue += b.value; usedBenefits++; }
    });
  });
  return { claimedValue, availableValue, totalBenefits, usedBenefits };
}

function computeUrgent() {
  const list = [];
  CARDS.forEach(card => {
    card.benefits.forEach(b => {
      if (b.passive) return;
      if (!isBenefitActiveNow(b.cadence)) return;
      if (usage[b.id + '::' + getCurrentPeriod(b.cadence)]) return;
      list.push({ card: card, benefit: b, days: daysUntilExpiry(b.cadence) });
    });
  });
  return list.sort((a, b) => a.days - b.days);
}

