<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Card Perks · Tracker</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600;9..144,800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --deep-space-blue: #1c3144;
    --granite: #596f62;
    --sage-green: #7ea16b;
    --sage-soft: #a8c098;
    --cream: #f5f1e8;
    --peach: #e8b896;
  }

  html, body {
    min-height: 100%;
    background: linear-gradient(160deg, #1c3144 0%, #2a4456 45%, #596f62 100%);
    color: var(--cream);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    -webkit-font-smoothing: antialiased;
  }

  .font-display { font-family: 'Fraunces', serif; font-optical-sizing: auto; }
  .font-mono { font-family: 'JetBrains Mono', monospace; }

  body::before {
    content: '';
    position: fixed; inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.5'/%3E%3C/svg%3E");
    opacity: 0.05;
    pointer-events: none;
    z-index: 1;
  }

  .wrap {
    position: relative;
    z-index: 2;
    max-width: 1100px;
    margin: 0 auto;
    padding: 32px 16px;
  }
  @media (min-width: 640px) { .wrap { padding: 48px 24px; } }
  @media (min-width: 1024px) { .wrap { padding: 48px 40px; } }

  /* ---------- HEADER ---------- */
  .header { margin-bottom: 48px; }
  @media (min-width: 640px) { .header { margin-bottom: 64px; } }
  .header-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; margin-bottom: 32px; }
  .eyebrow { font-size: 10px; letter-spacing: 0.3em; color: var(--sage-soft); margin-bottom: 12px; }
  .h1 { font-family: 'Fraunces', serif; font-weight: 300; font-size: clamp(28px, 6vw, 52px); line-height: 1.1; }
  .h1 .accent { font-style: italic; color: var(--sage-soft); }

  .reset-btn {
    background: transparent; border: none; cursor: pointer;
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    letter-spacing: 0.15em; color: var(--sage-soft); opacity: 0.6;
    display: flex; align-items: center; gap: 8px;
    margin-top: 8px;
    transition: opacity 0.2s;
  }
  .reset-btn:hover { opacity: 1; }
  .reset-btn svg { width: 12px; height: 12px; }

  .cat-lineup { display: flex; align-items: center; gap: 20px; flex-wrap: wrap; }
  @media (min-width: 640px) { .cat-lineup { gap: 32px; } }
  .cat-lineup-item { display: flex; align-items: center; gap: 8px; }
  .cat-lineup-item .cat-svg { opacity: 0.9; }
  .cat-name { font-family: 'Fraunces', serif; font-style: italic; font-size: 14px; color: var(--sage-soft); }
  .cat-role { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.08em; opacity: 0.5; }

  /* ---------- STATS ---------- */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    margin-bottom: 48px;
  }
  @media (min-width: 640px) {
    .stats-grid { grid-template-columns: repeat(4, 1fr); gap: 16px; }
  }
  .stat {
    border-radius: 12px;
    padding: 16px;
    border: 1px solid;
    backdrop-filter: blur(8px);
  }
  @media (min-width: 640px) { .stat { padding: 20px; } }
  .stat-label { font-family: 'JetBrains Mono', monospace; font-size: 9px; letter-spacing: 0.18em; opacity: 0.7; margin-bottom: 8px; }
  @media (min-width: 640px) { .stat-label { font-size: 10px; } }
  .stat-value { font-family: 'Fraunces', serif; font-weight: 300; font-size: 30px; line-height: 1; }
  @media (min-width: 640px) { .stat-value { font-size: 38px; } }
  .stat-sub { font-family: 'JetBrains Mono', monospace; font-size: 10px; opacity: 0.6; margin-top: 4px; }
  .stat-sage { border-color: rgba(126, 161, 107, 0.4); background: rgba(126, 161, 107, 0.08); }
  .stat-sage .stat-value { color: var(--sage-soft); }
  .stat-alert { border-color: rgba(232, 184, 150, 0.4); background: rgba(232, 184, 150, 0.08); }
  .stat-alert .stat-value { color: var(--peach); }
  .stat-neutral { border-color: rgba(245, 241, 232, 0.15); background: rgba(245, 241, 232, 0.03); }
  .stat-neutral .stat-value { color: var(--cream); }

  /* ---------- SECTIONS ---------- */
  .section { margin-bottom: 48px; }
  .section-head { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; }
  .section-head h2 { font-family: 'Fraunces', serif; font-style: italic; font-weight: 400; font-size: 22px; }
  @media (min-width: 640px) { .section-head h2 { font-size: 26px; } }
  .section-head h2.sage { color: var(--sage-soft); }
  .section-head-text { flex: 1; min-width: 0; }
  .section-head-text .sub { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.1em; opacity: 0.6; }
  .section-line { flex: 1; height: 1px; background: linear-gradient(to right, rgba(168, 192, 152, 0.4), transparent); }
  @media (max-width: 639px) { .section-line { display: none; } }
  .section-line-flat { flex: 1; height: 1px; background: rgba(168, 192, 152, 0.2); }

  /* ---------- URGENT GRID ---------- */
  .urgent-grid { display: grid; grid-template-columns: 1fr; gap: 12px; }
  @media (min-width: 640px) { .urgent-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .urgent-grid { grid-template-columns: repeat(3, 1fr); } }

  .urgent-card {
    position: relative;
    border-radius: 12px;
    padding: 16px;
    border: 1px solid rgba(168, 192, 152, 0.2);
    background: linear-gradient(135deg, rgba(245,241,232,0.04), rgba(245,241,232,0.01));
    transition: all 0.2s;
  }
  .urgent-card.is-urgent {
    border-color: rgba(232, 184, 150, 0.5);
    animation: tail-flick 2.4s infinite;
  }
  @keyframes tail-flick {
    0%, 100% { box-shadow: 0 0 0 0 rgba(126, 161, 107, 0.5); }
    50% { box-shadow: 0 0 0 8px rgba(126, 161, 107, 0); }
  }
  .urgent-card .uc-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 8px; margin-bottom: 8px; }
  .uc-cardname { font-family: 'JetBrains Mono', monospace; font-size: 9px; letter-spacing: 0.18em; color: var(--sage-soft); }
  .uc-days {
    font-family: 'JetBrains Mono', monospace; font-size: 9px; letter-spacing: 0.1em;
    padding: 2px 8px; border-radius: 999px; flex-shrink: 0;
    background: rgba(168, 192, 152, 0.1); color: var(--sage-soft);
  }
  .uc-days.is-urgent { background: rgba(232, 184, 150, 0.15); color: var(--peach); }
  .uc-body { display: flex; align-items: flex-start; gap: 12px; margin-bottom: 12px; }
  .uc-label { font-family: 'Fraunces', serif; font-size: 17px; line-height: 1.2; }
  .uc-detail { font-family: 'JetBrains Mono', monospace; font-size: 10px; line-height: 1.5; opacity: 0.7; margin-bottom: 16px;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .uc-cta {
    width: 100%; font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.18em;
    padding: 8px; border-radius: 6px; cursor: pointer;
    border: 1px solid rgba(168, 192, 152, 0.4);
    color: var(--sage-soft);
    background: rgba(126, 161, 107, 0.08);
    transition: transform 0.15s;
  }
  .uc-cta:hover { transform: scale(1.02); }

  /* ---------- EMPTY STATE ---------- */
  .empty {
    margin-bottom: 48px;
    padding: 32px;
    border-radius: 16px;
    text-align: center;
    border: 1px solid rgba(126, 161, 107, 0.3);
    background: linear-gradient(135deg, rgba(126, 161, 107, 0.15), rgba(126, 161, 107, 0.03));
  }
  .empty .cat-bob { display: inline-block; margin-bottom: 8px; }
  .empty .title { font-family: 'Fraunces', serif; font-style: italic; font-size: 22px; color: var(--sage-soft); }
  @media (min-width: 640px) { .empty .title { font-size: 26px; } }
  .empty .sub { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.1em; opacity: 0.7; margin-top: 4px; }

  /* ---------- CARD PANELS ---------- */
  .cards-list { display: flex; flex-direction: column; gap: 12px; }
  @media (min-width: 640px) { .cards-list { gap: 16px; } }

  .card-panel {
    border-radius: 16px;
    border: 1px solid rgba(245, 241, 232, 0.12);
    background: linear-gradient(180deg, rgba(245,241,232,0.03), rgba(245,241,232,0.005));
    overflow: hidden;
    transition: border-color 0.2s;
  }
  .card-panel.all-claimed { border-color: rgba(126, 161, 107, 0.3); }

  .card-head {
    width: 100%;
    display: flex; align-items: center; gap: 12px;
    padding: 16px;
    background: transparent; border: none; cursor: pointer; text-align: left;
    color: inherit;
    transition: background 0.15s;
  }
  @media (min-width: 640px) { .card-head { padding: 24px; gap: 16px; } }
  .card-head:hover { background: rgba(255,255,255,0.02); }

  .card-head .chip-and-cat { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
  .card-chip {
    width: 56px; height: 36px; border-radius: 6px;
    display: none; align-items: center; justify-content: center;
    position: relative; overflow: hidden;
  }
  @media (min-width: 640px) { .card-chip { display: flex; } }
  .card-chip::before {
    content:''; position: absolute; inset: 0; opacity: 0.3;
    background: repeating-linear-gradient(45deg, transparent, transparent 2px, rgba(255,255,255,0.1) 2px, rgba(255,255,255,0.1) 4px);
  }
  .card-chip .gold-square { width: 20px; height: 14px; border-radius: 2px; background: rgba(245, 241, 232, 0.5); position: relative; z-index: 1; }

  .card-info { flex: 1; min-width: 0; }
  .card-title-row { display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap; }
  .card-name { font-family: 'Fraunces', serif; font-size: 18px; }
  @media (min-width: 640px) { .card-name { font-size: 24px; } }
  .card-meta { font-family: 'JetBrains Mono', monospace; font-size: 9px; letter-spacing: 0.12em; opacity: 0.6; }
  @media (min-width: 640px) { .card-meta { font-size: 10px; } }
  .card-earnings { font-family: 'JetBrains Mono', monospace; font-size: 10px; opacity: 0.7; margin-top: 6px;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  @media (min-width: 640px) { .card-earnings { font-size: 11px; } }

  .card-right { text-align: right; flex-shrink: 0; }
  .card-count { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.1em; opacity: 0.7; }
  .card-count .claimed { color: var(--cream); }
  .card-count .claimed.all { color: var(--sage-soft); }
  .card-count .total { opacity: 0.5; }
  .card-chevron { opacity: 0.6; margin-top: 4px; display: inline-flex; }

  .card-body { padding: 12px 16px 20px; border-top: 1px solid rgba(245, 241, 232, 0.08); }
  @media (min-width: 640px) { .card-body { padding: 12px 24px 24px; } }

  /* ---------- BENEFIT ROW ---------- */
  .benefit {
    display: flex; align-items: flex-start; gap: 12px;
    padding: 12px;
    border-radius: 8px;
    transition: all 0.2s;
  }
  @media (min-width: 640px) { .benefit { padding: 16px; gap: 16px; } }
  .benefit.used { background: rgba(126, 161, 107, 0.08); opacity: 0.7; }

  .check-btn {
    flex-shrink: 0;
    width: 24px; height: 24px;
    border-radius: 6px;
    border: 2px solid rgba(245, 241, 232, 0.35);
    background: transparent;
    cursor: pointer;
    margin-top: 2px;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.2s;
  }
  .check-btn.checked { border-color: var(--sage-green); background: var(--sage-green); }
  .check-btn svg { width: 14px; height: 14px; color: var(--deep-space-blue); animation: pop 0.3s cubic-bezier(0.34, 1.56, 0.64, 1); }
  @keyframes pop { 0% { transform: scale(0); } 100% { transform: scale(1); } }

  .check-placeholder {
    flex-shrink: 0; width: 24px; height: 24px;
    display: flex; align-items: center; justify-content: center;
    margin-top: 2px;
    opacity: 0.4;
  }
  .check-placeholder svg { width: 14px; height: 14px; }

  .benefit-cat { flex-shrink: 0; margin-top: 2px; opacity: 0.9; }

  .benefit-main { flex: 1; min-width: 0; }
  .benefit-title-row { display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap; }
  .benefit-title { font-family: 'Fraunces', serif; font-size: 16px; }
  @media (min-width: 640px) { .benefit-title { font-size: 18px; } }
  .benefit-title.used { text-decoration: line-through; opacity: 0.6; }
  .benefit-value { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.1em; color: var(--sage-soft); }
  .activation-badge {
    font-family: 'JetBrains Mono', monospace; font-size: 9px; letter-spacing: 0.18em;
    padding: 2px 6px; border-radius: 4px;
    color: var(--peach); background: rgba(232, 184, 150, 0.15);
  }
  .benefit-detail { font-family: 'JetBrains Mono', monospace; font-size: 10px; line-height: 1.5; opacity: 0.7; margin-top: 4px; }
  @media (min-width: 640px) { .benefit-detail { font-size: 11px; } }
  .benefit-meta { font-family: 'JetBrains Mono', monospace; font-size: 10px; margin-top: 8px; display: flex; align-items: center; gap: 8px; opacity: 0.6; }
  .benefit-meta svg { width: 10px; height: 10px; }
  .benefit-claimed-note { font-family: 'JetBrains Mono', monospace; font-size: 10px; margin-top: 8px; display: flex; align-items: center; gap: 8px; color: var(--sage-soft); }
  .benefit-claimed-note svg { width: 10px; height: 10px; }
  .benefit-claimed-note .approves { font-style: italic; }

  /* ---------- FOOTER ---------- */
  footer { margin-top: 64px; padding-top: 32px; border-top: 1px solid rgba(168, 192, 152, 0.15); }
  .footer-note { display: flex; align-items: flex-start; gap: 12px; margin-bottom: 16px; }
  .footer-note .cat-svg { opacity: 0.6; flex-shrink: 0; }
  .footer-note .text {
    font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.05em;
    opacity: 0.6; line-height: 1.6; flex: 1;
  }
  .footer-note .text .name { color: var(--sage-soft); }

  /* ---------- LOADING ---------- */
  .loading {
    min-height: 100vh; display: flex; align-items: center; justify-content: center;
    font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: 0.15em; color: var(--cream);
  }

  .cat-bob { animation: purr 4s ease-in-out infinite; display: inline-block; }
  @keyframes purr { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-2px); } }
</style>
</head>
<body>

<div id="app"></div>

<script>
/* ================================================================
   DATA
================================================================ */

// ---------- CAT SVGs (returns HTML string) ----------
function catSVG(which, size) {
  size = size || 32;
  if (which === 'napper') {
    return `<svg class="cat-svg" viewBox="0 0 100 100" width="${size}" height="${size}">
      <ellipse cx="50" cy="68" rx="38" ry="22" fill="#f5f1e8"/>
      <ellipse cx="35" cy="62" rx="14" ry="10" fill="#7a6d5e" opacity="0.5"/>
      <ellipse cx="62" cy="70" rx="18" ry="12" fill="#f5f1e8"/>
      <circle cx="38" cy="58" r="14" fill="#f5f1e8"/>
      <path d="M 30 50 L 33 42 L 38 48 Z" fill="#7a6d5e"/>
      <path d="M 42 48 L 47 42 L 45 52 Z" fill="#f5f1e8"/>
