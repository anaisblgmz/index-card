                  Luci says: use these soon
                </h2>
                <div className="font-mono text-[10px] tracking-wider opacity-60">EXPIRES THIS MONTH OR QUARTER</div>
              </div>
              <div className="hidden sm:block flex-1 h-px" style={{background:'linear-gradient(to right, rgba(168, 192, 152, 0.4), transparent)'}}/>
            </div>
            <div className="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
              {urgentBenefits.slice(0, 6).map(({ card, benefit, days }) => (
                <UrgentCard
                  key={benefit.id}
                  card={card}
                  benefit={benefit}
                  days={days}
                  onClaim={() => toggleBenefit(benefit.id, benefit.cadence)}
                />
              ))}
            </div>
          </section>
        )}

        {urgentBenefits.length === 0 && (
          <section className="mb-12 p-6 sm:p-8 rounded-2xl text-center relative overflow-hidden"
            style={{
              background:'linear-gradient(135deg, rgba(126, 161, 107, 0.15), rgba(126, 161, 107, 0.03))',
              border:'1px solid rgba(126, 161, 107, 0.3)'
            }}>
            <div className="cat-bob inline-block mb-2">{CATS.napper.svg(54)}</div>
            <div className="font-display text-xl sm:text-2xl italic" style={{color: '#a8c098'}}>
              Gatito is purring. All caught up.
            </div>
            <div className="font-mono text-[10px] tracking-wider mt-1 opacity-70">EVERY ACTIVE PERK CLAIMED THIS PERIOD</div>
          </section>
        )}

        {/* CARDS */}
        <section>
          <div className="flex items-center gap-3 mb-6">
            <CreditCard size={20} style={{color:'#a8c098'}}/>
            <h2 className="font-display text-xl sm:text-2xl italic">Your wallet</h2>
            <div className="flex-1 h-px" style={{background:'rgba(168, 192, 152, 0.2)'}}/>
          </div>

          <div className="space-y-3 sm:space-y-4">
            {CARDS.map(card => (
              <CardPanel
                key={card.id}
                card={card}
                expanded={expandedCards.has(card.id)}
                onToggle={() => toggleCardExpanded(card.id)}
                usage={usage}
                onToggleBenefit={toggleBenefit}
              />
            ))}
          </div>
        </section>

        {/* FOOTER */}
        <footer className="mt-16 pt-8" style={{borderTop:'1px solid rgba(168, 192, 152, 0.15)'}}>
          <div className="flex items-start gap-3 mb-4">
            <div className="opacity-60">{CATS.strategist.svg(32)}</div>
            <div className="font-mono text-[10px] tracking-wider opacity-60 leading-relaxed flex-1">
              <span style={{color:'#a8c098'}}>Loki's notes:</span> Benefits data verified via web search May 2026. Always confirm current terms at issuer site. Enrollment required for Amex statement credits (Dining, Resy, Dunkin'). Chase Freedom Flex quarterly categories require activation on chase.com. Your tracker data persists across sessions.
            </div>
          </div>
          <div className="flex items-center justify-center gap-2 opacity-30 pt-4">
            <PawPrint size={10}/><PawPrint size={10}/><PawPrint size={10}/>
          </div>
        </footer>
      </div>
    </div>
  );
}

// ---------- COMPONENTS ----------
function StatTile({ label, value, sub, tone = 'neutral' }) {
  const toneStyles = {
    sage: { color: '#a8c098', border: 'rgba(126, 161, 107, 0.4)', bg: 'rgba(126, 161, 107, 0.08)' },
    alert: { color: '#e8b896', border: 'rgba(232, 184, 150, 0.4)', bg: 'rgba(232, 184, 150, 0.08)' },
    neutral: { color: '#f5f1e8', border: 'rgba(245, 241, 232, 0.15)', bg: 'rgba(245, 241, 232, 0.03)' },
  }[tone];
  return (
    <div
      className="rounded-xl p-4 sm:p-5 border backdrop-blur-sm"
      style={{ borderColor: toneStyles.border, background: toneStyles.bg }}
    >
      <div className="font-mono text-[9px] sm:text-[10px] tracking-[0.18em] mb-2 opacity-70">{label}</div>
      <div className="font-display text-3xl sm:text-4xl font-light" style={{ color: toneStyles.color }}>{value}</div>
      <div className="font-mono text-[10px] opacity-60 mt-1">{sub}</div>
    </div>
  );
}

function UrgentCard({ card, benefit, days, onClaim }) {
  const urgent = days <= 7;
  const cat = CATS[benefit.cat] || CATS.watcher;
  return (
    <div
      className={`relative rounded-xl p-4 border transition-all ${urgent ? 'pulse-urgent' : ''}`}
      style={{
        borderColor: urgent ? 'rgba(232, 184, 150, 0.5)' : 'rgba(168, 192, 152, 0.2)',
        background: `linear-gradient(135deg, rgba(245,241,232,0.04), rgba(245,241,232,0.01))`,
      }}
    >
      <div className="flex items-start justify-between mb-2 gap-2">
        <div className="font-mono text-[9px] tracking-widest" style={{ color: '#a8c098' }}>
          {card.name.toUpperCase()}
        </div>
        <div className={`font-mono text-[9px] tracking-wider px-2 py-0.5 rounded-full flex-shrink-0`}
          style={{
            background: urgent ? 'rgba(232, 184, 150, 0.15)' : 'rgba(168, 192, 152, 0.1)',
            color: urgent ? '#e8b896' : '#a8c098'
          }}>
          {days === 0 ? 'TODAY' : `${days}D LEFT`}
        </div>
      </div>
      <div className="flex items-start gap-3 mb-3">
        <div className="flex-shrink-0 mt-1">{cat.svg(28)}</div>
        <div className="flex-1 min-w-0">
          <div className="font-display text-base sm:text-lg leading-tight">{benefit.label}</div>
        </div>
      </div>
      <div className="font-mono text-[10px] mb-4 leading-relaxed opacity-70 line-clamp-2">{benefit.detail}</div>
      <button
        onClick={onClaim}
        className="w-full font-mono text-[10px] tracking-[0.18em] py-2 rounded-md transition hover:scale-[1.02]"
        style={{
          border: '1px solid rgba(168, 192, 152, 0.4)',
          color: '#a8c098',
          background: 'rgba(126, 161, 107, 0.08)'
        }}
      >
        MARK AS USED 🐾
      </button>
    </div>
  );
}

function CardPanel({ card, expanded, onToggle, usage, onToggleBenefit }) {
  const activeBenefits = card.benefits.filter(b => isBenefitActiveNow(b.cadence));
  const claimableBenefits = activeBenefits.filter(b => !b.passive);
  const claimed = claimableBenefits.filter(b => usage[`${b.id}::${getCurrentPeriod(b.cadence)}`]).length;
  const total = claimableBenefits.length;
  const cardCat = CATS[card.cat] || CATS.strategist;
  const allClaimed = total > 0 && claimed === total;

  return (
    <div
      className="rounded-2xl border overflow-hidden transition-all"
      style={{
        borderColor: allClaimed ? 'rgba(126, 161, 107, 0.3)' : 'rgba(245, 241, 232, 0.12)',
        background: 'linear-gradient(180deg, rgba(245,241,232,0.03), rgba(245,241,232,0.005))'
      }}
    >
      <button
        onClick={onToggle}
        className="w-full flex items-center gap-3 sm:gap-4 p-4 sm:p-6 text-left hover:bg-white/[0.02] transition"
      >
        {/* Card chip + cat */}
        <div className="flex items-center gap-2 flex-shrink-0">
          <div
            className="hidden sm:flex w-14 h-9 rounded-md items-center justify-center relative overflow-hidden"
            style={{ background: `linear-gradient(135deg, ${card.color}, ${card.color}cc)` }}
          >
            <div className="absolute inset-0 opacity-30" style={{
              background: 'repeating-linear-gradient(45deg, transparent, transparent 2px, rgba(255,255,255,0.1) 2px, rgba(255,255,255,0.1) 4px)'
            }}/>
            <div className="w-5 h-3.5 rounded-sm relative z-10" style={{background: 'rgba(245, 241, 232, 0.5)'}}/>
          </div>
          <div className="flex-shrink-0">{cardCat.svg(36)}</div>
        </div>

        <div className="flex-1 min-w-0">
          <div className="flex items-baseline gap-2 flex-wrap">
            <div className="font-display text-lg sm:text-2xl">{card.name}</div>
            <div className="font-mono text-[9px] sm:text-[10px] tracking-wider opacity-60">
              {card.issuer.toUpperCase()} · ${card.annualFee}/YR
            </div>
          </div>
          <div className="font-mono text-[10px] sm:text-[11px] mt-1.5 opacity-70 line-clamp-1">{card.earnings}</div>
        </div>

        <div className="text-right flex-shrink-0">
          {total > 0 && (
            <div className="font-mono text-[10px] tracking-wider opacity-70">
              <span style={{color: allClaimed ? '#a8c098' : '#f5f1e8'}}>{claimed}</span>
              <span className="opacity-50">/{total}</span> DONE
            </div>
          )}
          <div className="opacity-60 mt-1">
            {expanded ? <ChevronUp size={16}/> : <ChevronDown size={16}/>}
          </div>
        </div>
      </button>

      {expanded && (
        <div className="px-4 sm:px-6 pb-5 sm:pb-6 space-y-2 pt-3" style={{borderTop:'1px solid rgba(245, 241, 232, 0.08)'}}>
          {activeBenefits.map(benefit => {
            const period = getCurrentPeriod(benefit.cadence);
            const used = !!usage[`${benefit.id}::${period}`];
            const days = daysUntilExpiry(benefit.cadence);
            return (
              <BenefitRow
                key={benefit.id}
                benefit={benefit}
                used={used}
                days={days}
                isActionable={!benefit.passive}
                onToggle={() => onToggleBenefit(benefit.id, benefit.cadence)}
              />
            );
          })}
        </div>
      )}
    </div>
  );
}

function BenefitRow({ benefit, used, days, isActionable, onToggle }) {
  const cat = CATS[benefit.cat] || CATS.napper;
  return (
    <div
      className="flex items-start gap-3 sm:gap-4 p-3 sm:p-4 rounded-lg transition-all"
      style={{
        background: used ? 'rgba(126, 161, 107, 0.08)' : 'transparent',
        opacity: used ? 0.7 : 1
      }}
    >
      {/* Checkbox */}
      {isActionable ? (
        <button
          onClick={onToggle}
          className="flex-shrink-0 w-6 h-6 rounded-md border-2 flex items-center justify-center transition-all mt-0.5"
          style={{
            borderColor: used ? '#7ea16b' : 'rgba(245, 241, 232, 0.35)',
            background: used ? '#7ea16b' : 'transparent'
          }}
          aria-label={used ? 'Mark as not used' : 'Mark as used'}
        >
          {used && <Check size={14} className="check-anim" strokeWidth={3} style={{color:'#1c3144'}}/>}
        </button>
      ) : (
        <div className="flex-shrink-0 w-6 h-6 flex items-center justify-center mt-0.5">
          <TrendingUp size={14} style={{color:'rgba(245, 241, 232, 0.4)'}}/>
        </div>
      )}

      {/* Cat marker */}
      <div className="flex-shrink-0 mt-0.5 opacity-90">{cat.svg(28)}</div>

      <div className="flex-1 min-w-0">
        <div className="flex items-baseline gap-2 flex-wrap">
          <div className={`font-display text-base sm:text-lg ${used ? 'line-through opacity-60' : ''}`}>
            {benefit.label}
          </div>
          {benefit.value > 0 && (
            <div className="font-mono text-[10px] tracking-wider" style={{color: '#a8c098'}}>
              ${benefit.value} VALUE
            </div>
          )}
          {benefit.activation && !used && (
            <div className="font-mono text-[9px] tracking-widest px-1.5 py-0.5 rounded"
              style={{color: '#e8b896', background: 'rgba(232, 184, 150, 0.15)'}}>
              ACTIVATE
            </div>
          )}
        </div>
        <div className="font-mono text-[10px] sm:text-[11px] mt-1 leading-relaxed opacity-70">
          {benefit.detail}
        </div>
        {isActionable && !used && (
          <div className="font-mono text-[10px] mt-2 flex items-center gap-2 opacity-60">
            <Clock size={10}/>
            <span>{cadenceLabel(benefit.cadence)} · {days === 0 ? 'expires today' : `${days} day${days===1?'':'s'} left`}</span>
          </div>
        )}
        {used && (
          <div className="font-mono text-[10px] mt-2 flex items-center gap-2" style={{color: '#a8c098'}}>
            <Check size={10}/>
            <span>Claimed this period · <span className="italic">{cat.name} approves</span></span>
          </div>
        )}
      </div>
    </div>
  );
}
