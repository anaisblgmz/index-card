  const cat = CATS[benefit.cat] || CATS.napper;

  const checkbox = isActionable
    ? `<button class="check-btn ${used ? 'checked' : ''}" onclick="toggleBenefit('${benefit.id}', '${benefit.cadence}')" aria-label="${used ? 'Mark as not used' : 'Mark as used'}">
         ${used ? ICONS.check : ''}
       </button>`
    : `<div class="check-placeholder">${ICONS.trending}</div>`;

  const valueBadge = benefit.value > 0 ? `<span class="benefit-value">$${benefit.value} VALUE</span>` : '';
  const activationBadge = (benefit.activation && !used) ? `<span class="activation-badge">ACTIVATE</span>` : '';

  const footerLine = used
    ? `<div class="benefit-claimed-note">${ICONS.check}<span>Claimed this period · <span class="approves">${cat.name} approves</span></span></div>`
    : (isActionable
        ? `<div class="benefit-meta">${ICONS.clock}<span>${cadenceLabel(benefit.cadence)} · ${days === 0 ? 'expires today' : days + ' day' + (days===1?'':'s') + ' left'}</span></div>`
        : '');

  return `
    <div class="benefit ${used ? 'used' : ''}">
      ${checkbox}
      <div class="benefit-cat">${catSVG(benefit.cat || 'napper', 28)}</div>
      <div class="benefit-main">
        <div class="benefit-title-row">
          <span class="benefit-title ${used ? 'used' : ''}">${escapeHtml(benefit.label)}</span>
